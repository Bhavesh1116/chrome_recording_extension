{
    "manifest_version": 3,
    "name": "RecordSnap - Tutorial Recording Tool",
    "version": "2.0",
    "description": "Professional tutorial recording tool. Capture user interactions and generate step-by-step documentation with screenshots.",
    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "scripting",
        "tabCapture",
        "webNavigation"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "RecordSnap - Tutorial Recording"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}